        {
          "id": "paragraph_1",
          "type": "ParagraphBlock",
          "content": "كلية التربية"
        },
        {
          "id": "paragraph_2",
          "type": "ParagraphBlock",
          "content": "قسم تكنولوجيا التعليم"
        },
        {
          "id": "paragraph_3",
          "type": "ParagraphBlock",
          "content": "قائمة مهارات التحول الرقمي المهنية"
        },
        {
          "id": "paragraph_4",
          "type": "ParagraphBlock",
          "content": "لدي القيادات التعليمية"
        },
        {
          "id": "paragraph_5",
          "type": "ParagraphBlock",
          "content": "إعداد"
        },
        {
          "id": "paragraph_6",
          "type": "ParagraphBlock",
          "content": "أيه محمد عنتر على"
        },
        {
